{
  "version": 2,
  "env": {
    "NODE_ENV": "production"
  },
  "installCommand": "npm ci --prefer-offline --no-audit --progress=false --prefix frontend",
  "buildCommand": "npm --prefix frontend run build",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/build"
      }
    }
  ],
  "routes": [
    {
      "src": "^/(?!api).*",
      "dest": "frontend/build/index.html"
    }
  ],
  "cleanUrls": true
}
